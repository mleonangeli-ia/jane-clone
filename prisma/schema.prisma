generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id                String   @id @default(cuid())
  name              String
  slug              String   @unique
  email             String   @unique
  passwordHash      String
  bio               String?
  phone             String?
  address           String?
  timezone          String   @default("America/Argentina/Buenos_Aires")
  currency          String   @default("ARS")
  logoUrl           String?
  accentColor       String   @default("#4F46E5")
  cancelWindowHours Int      @default(2)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  googleRefreshToken String?

  services        Service[]
  availability    Availability[]
  appointments    Appointment[]
  clients         Client[]
  intakeForms     IntakeForm[]
  waitlistEntries WaitlistEntry[]

  @@map("tenants")
}

model Service {
  id           String   @id @default(cuid())
  tenantId     String
  name         String
  description  String?
  duration     Int
  price        Int
  color        String   @default("#4F46E5")
  isActive     Boolean  @default(true)
  intakeFormId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointments    Appointment[]
  intakeForm      IntakeForm?     @relation("ServiceForm", fields: [intakeFormId], references: [id])
  waitlistEntries WaitlistEntry[]

  @@map("services")
}

model Availability {
  id        String  @id @default(cuid())
  tenantId  String
  dayOfWeek Int
  startTime String
  endTime   String
  isActive  Boolean @default(true)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, dayOfWeek])
  @@map("availability")
}

model Client {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  email     String
  phone     String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@unique([tenantId, email])
  @@map("clients")
}

model Appointment {
  id             String            @id @default(cuid())
  tenantId       String
  serviceId      String
  clientId       String
  startTime      DateTime
  endTime        DateTime
  status         AppointmentStatus @default(PENDING)
  notes          String?
  paymentStatus  PaymentStatus     @default(UNPAID)
  mpPreferenceId String?           @unique @map("stripeCheckoutSession")
  googleEventId  String?
  reminderSentAt DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  tenant         Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  service        Service       @relation(fields: [serviceId], references: [id])
  client         Client        @relation(fields: [clientId], references: [id])
  payment        Payment?
  intakeResponse FormResponse?

  @@map("appointments")
}

model Payment {
  id             String        @id @default(cuid())
  appointmentId  String        @unique
  amount         Int
  currency       String        @default("ars")
  mpPaymentId    String?       @map("stripePaymentIntentId")
  mpPreferenceId String?       @map("stripeCheckoutSession")
  status         PaymentStatus @default(UNPAID)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model IntakeForm {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant    Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fields    IntakeFormField[]
  responses FormResponse[]
  services  Service[]         @relation("ServiceForm")

  @@map("intake_forms")
}

model IntakeFormField {
  id       String    @id @default(cuid())
  formId   String
  label    String
  type     FieldType
  options  String?
  required Boolean   @default(false)
  position Int       @default(0)

  form    IntakeForm   @relation(fields: [formId], references: [id], onDelete: Cascade)
  answers FormAnswer[]

  @@map("intake_form_fields")
}

model FormResponse {
  id            String    @id @default(cuid())
  appointmentId String    @unique
  formId        String
  submittedAt   DateTime?
  createdAt     DateTime  @default(now())

  appointment Appointment  @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  form        IntakeForm   @relation(fields: [formId], references: [id])
  answers     FormAnswer[]

  @@map("form_responses")
}

model FormAnswer {
  id         String @id @default(cuid())
  responseId String
  fieldId    String
  value      String

  response FormResponse    @relation(fields: [responseId], references: [id], onDelete: Cascade)
  field    IntakeFormField @relation(fields: [fieldId], references: [id])

  @@map("form_answers")
}

model WaitlistEntry {
  id         String    @id @default(cuid())
  tenantId   String
  serviceId  String
  date       String
  name       String
  email      String
  phone      String?
  notifiedAt DateTime?
  createdAt  DateTime  @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([tenantId, serviceId, date])
  @@map("waitlist_entries")
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
  FAILED
}

enum FieldType {
  TEXT
  TEXTAREA
  SELECT
  CHECKBOX
  DATE
}
